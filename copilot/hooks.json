{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python scripts/session_init.py",
        "cwd": "copilot/hooks",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python scripts/session_end.py",
        "cwd": "copilot/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "python scripts/unified-pre-hook.py",
        "cwd": "copilot/hooks",
        "timeoutSec": 5
      }
    ],
    "preCompact": [
      {
        "type": "command",
        "bash": "python pre-compact.py",
        "cwd": "copilot/hooks",
        "timeoutSec": 5
      }
    ]
  }
}